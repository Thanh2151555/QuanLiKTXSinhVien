<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <session-config>
        <session-timeout>5</session-timeout>
    </session-config>
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>Filter.AuthFilter</filter-class>
    </filter>
    <filter>
        <filter-name>StudentRoleFilter</filter-name>
        <filter-class>Filter.StudentRoleFilter</filter-class>
    </filter>
    <filter>
        <filter-name>ManagerRoleFilter</filter-name>
        <filter-class>Filter.ManagerRoleFilter</filter-class>
    </filter>
    <filter>
        <filter-name>AdminRoleFilter</filter-name>
        <filter-class>Filter.AdminRoleFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AdminRoleFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>ManagerRoleFilter</filter-name>
        <url-pattern>/manager/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>StudentRoleFilter</filter-name>
        <url-pattern>/student/*</url-pattern>
    </filter-mapping>
    <servlet>
        <servlet-name>LoginController</servlet-name>
        <servlet-class>Controller.LoginController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>StudentHomeController</servlet-name>
        <servlet-class>Controller.StudentHomeController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>StudentLoginController</servlet-name>
        <servlet-class>Controller.StudentHomeController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>StudentInforController</servlet-name>
        <servlet-class>Controller.StudentInforController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LogoutController</servlet-name>
        <servlet-class>Controller.LogoutController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>StudentRoomController</servlet-name>
        <servlet-class>Controller.StudentRoomController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>StudentPayment</servlet-name>
        <servlet-class>Controller.StudentPaymentController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>StudentRequestController</servlet-name>
        <servlet-class>Controller.StudentRequestController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>StudentNotificationController</servlet-name>
        <servlet-class>Controller.StudentNotificationController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ManagerHomeController</servlet-name>
        <servlet-class>Controller.ManagerHomeController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ManagerStudentController</servlet-name>
        <servlet-class>Controller.ManagerStudentController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ManagerStudentDetailController</servlet-name>
        <servlet-class>Controller.ManagerStudentDetailController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ManagerRoomController</servlet-name>
        <servlet-class>Controller.ManagerRoomController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ManagerRoomDetailController</servlet-name>
        <servlet-class>Controller.ManagerRoomDetailController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ManagerContractController</servlet-name>
        <servlet-class>Controller.ManagerContractController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ManagerPaymentController</servlet-name>
        <servlet-class>Controller.ManagerPaymentController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ManagerRequestController</servlet-name>
        <servlet-class>Controller.ManagerRequestController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ManagerNotificationController</servlet-name>
        <servlet-class>Controller.ManagerNotificationController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ManagerCreateStudentController</servlet-name>
        <servlet-class>Controller.ManagerCreateStudentController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AdminManagerController</servlet-name>
        <servlet-class>Controller.AdminManagerController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginController</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>StudentLoginController</servlet-name>
        <url-pattern>/student/home</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>StudentInforController</servlet-name>
        <url-pattern>/student/infor</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LogoutController</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>StudentRoomController</servlet-name>
        <url-pattern>/student/room</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>StudentPayment</servlet-name>
        <url-pattern>/student/payment</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>StudentRequestController</servlet-name>
        <url-pattern>/student/request</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>StudentNotificationController</servlet-name>
        <url-pattern>/student/notification</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ManagerHomeController</servlet-name>
        <url-pattern>/manager/home</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ManagerStudentController</servlet-name>
        <url-pattern>/manager/students</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ManagerStudentDetailController</servlet-name>
        <url-pattern>/manager/students/student-detail</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ManagerRoomController</servlet-name>
        <url-pattern>/manager/rooms</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ManagerRoomDetailController</servlet-name>
        <url-pattern>/manager/rooms/room-detail</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ManagerContractController</servlet-name>
        <url-pattern>/manager/contracts</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ManagerPaymentController</servlet-name>
        <url-pattern>/manager/payments</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ManagerRequestController</servlet-name>
        <url-pattern>/manager/requests</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ManagerNotificationController</servlet-name>
        <url-pattern>/manager/notifications</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ManagerCreateStudentController</servlet-name>
        <url-pattern>/manager/create-student</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AdminManagerController</servlet-name>
        <url-pattern>/admin/managers</url-pattern>
    </servlet-mapping>
</web-app>
